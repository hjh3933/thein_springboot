<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hjh.batis.mapper.MyMapper">

    <select id="selectMember" resultType="com.hjh.batis.model.Member">
        SELECT *
        FROM member
    </select>
    
    <insert id="insertMember">
    	INSERT INTO member(name)
        VALUES (#{name})
    </insert>

</mapper>